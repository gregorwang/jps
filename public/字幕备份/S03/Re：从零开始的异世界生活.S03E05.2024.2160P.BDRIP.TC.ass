Comment: 0,0:20:52.94,0:20:56.69,screen,,0,0,0,,{\an5\pos(960,250)\fs150}濁流
Comment: 0,0:00:00.00,0:00:00.00,screen,,0,0,0,,
Comment: 0,0:00:00.00,0:00:00.00,Default,,0,0,0,,
Dialogue: 0,0:00:01.07,0:00:04.04,Default,,0,0,0,,艾米莉亞 妳是處女嗎
Dialogue: 0,0:00:04.04,0:00:06.99,Default,,0,0,0,,這點真的很重要
Dialogue: 0,0:00:10.84,0:00:12.44,Default,,0,0,0,,抱歉抱歉
Dialogue: 0,0:00:12.44,0:00:15.16,Default,,0,0,0,,太過突然嚇到妳了
Dialogue: 0,0:00:15.56,0:00:17.21,Default,,0,0,0,,我誠心向妳謝罪
Dialogue: 0,0:00:18.27,0:00:22.46,Default,,0,0,0,,我和那些不願認錯的卑鄙小人不一樣
Dialogue: 0,0:00:23.42,0:00:26.42,Default,,0,0,0,,會真心道歉的確是件很重要的事
Dialogue: 0,0:00:26.42,0:00:31.64,Default,,0,0,0,,這個世界卻無比地多的人不懂這麼重要道理
Dialogue: 0,0:00:32.58,0:00:35.27,Default,,0,0,0,,妳果然是位美妙的女性
Dialogue: 0,0:00:36.04,0:00:38.62,Default,,0,0,0,,現在我想重新問妳一次
Dialogue: 0,0:00:38.62,0:00:41.48,Default,,0,0,0,,艾米莉亞 妳是處女嗎
Dialogue: 0,0:00:43.02,0:00:44.18,Default,,0,0,0,,到底是不是
Dialogue: 0,0:00:44.98,0:00:47.73,Default,,0,0,0,,那個 請問處女是甚麼
Dialogue: 0,0:00:47.73,0:00:50.20,Default,,0,0,0,,對不起 我沒有聽過
Dialogue: 0,0:00:50.49,0:00:52.40,Default,,0,0,0,,太美妙了
Dialogue: 0,0:00:52.40,0:00:55.79,Default,,0,0,0,,妳正是我理想中的女性
Dialogue: 0,0:00:56.13,0:00:58.58,Default,,0,0,0,,身體是處女是理所當然的
Dialogue: 0,0:00:59.07,0:01:00.42,Default,,0,0,0,,真正重要的是
Dialogue: 0,0:01:00.42,0:01:03.02,Default,,0,0,0,,連心靈都是處女這點
Dialogue: 0,0:01:03.42,0:01:06.58,Default,,0,0,0,,妳告訴了我新的真理
Dialogue: 0,0:01:06.58,0:01:07.71,Default,,0,0,0,,是嗎
Dialogue: 0,0:01:08.00,0:01:09.33,Default,,0,0,0,,是啊
Dialogue: 0,0:01:10.27,0:01:12.68,Default,,0,0,0,,不好 遲了做自我介紹
Dialogue: 0,0:01:13.20,0:01:15.33,Default,,0,0,0,,我是雷古魯斯·柯尼亞斯
Dialogue: 0,0:01:15.73,0:01:18.00,Default,,0,0,0,,是妳重要的老公
Dialogue: 0,0:01:18.00,0:01:21.10,Default,,0,0,0,,妳是我所愛的第79號老婆
Dialogue: 0,0:01:22.58,0:01:24.36,Default,,0,0,0,,我幫妳準備好衣服了
Dialogue: 0,0:01:29.42,0:01:33.38,Default,,0,0,0,,184號 幫79號換衣服
Dialogue: 0,0:01:33.38,0:01:35.82,Default,,0,0,0,,她將會得到和妳們相同的地位
Dialogue: 0,0:01:35.82,0:01:38.04,Default,,0,0,0,,要和睦相處 好好照顧她
Dialogue: 0,0:01:39.33,0:01:40.71,Default,,0,0,0,,真是個乖孩子
Dialogue: 0,0:01:40.71,0:01:42.96,Default,,0,0,0,,有聽我說 不再笑了
Dialogue: 0,0:01:48.22,0:01:50.53,Default,,0,0,0,,那麼 我們之後再見
Dialogue: 0,0:01:57.87,0:01:58.93,Default,,0,0,0,,請更衣
Dialogue: 0,0:01:58.93,0:01:59.96,Default,,0,0,0,,妳是？
Dialogue: 0,0:02:00.44,0:02:01.91,Default,,0,0,0,,是184號
Dialogue: 0,0:02:02.36,0:02:04.44,Default,,0,0,0,,和妳一樣 是他的妻子
Dialogue: 0,0:02:04.44,0:02:08.67,Default,,0,0,0,,我沒打算成為他的老婆
Dialogue: 0,0:02:09.02,0:02:10.44,Default,,0,0,0,,他有這個意思
Dialogue: 0,0:02:10.93,0:02:13.38,Default,,0,0,0,,既然他有這個意思
Dialogue: 0,0:02:13.38,0:02:15.87,Default,,0,0,0,,那就和妳的想法沒關係了
Dialogue: 0,0:02:16.80,0:02:18.44,Default,,0,0,0,,這樣太奇怪了
Dialogue: 0,0:02:20.27,0:02:24.00,Default,,0,0,0,,總覺得他和我在書上看過的壞國王一樣
Dialogue: 0,0:02:25.20,0:02:26.53,Default,,0,0,0,,真是形容得很貼切
Dialogue: 0,0:02:27.91,0:02:30.22,Default,,0,0,0,,他的存在確實是王
Dialogue: 0,0:02:30.89,0:02:33.34,Default,,0,0,0,,應該配得上小王的名號
Dialogue: 0,0:02:36.00,0:02:37.16,Default,,0,0,0,,請更衣
Dialogue: 0,0:02:40.44,0:02:41.56,Default,,0,0,0,,昴
Dialogue: 0,0:04:14.58,0:04:16.67,Default,,0,0,0,,暴食
Dialogue: 0,0:04:26.36,0:04:28.46,Default,,0,0,0,,想起你的目的 幼女使
Dialogue: 0,0:04:30.76,0:04:33.84,Default,,0,0,0,,如果遇到了暴食 絕對不要說出自己的真名
Dialogue: 0,0:04:34.40,0:04:36.53,Default,,0,0,0,,我們是為了甚麼才來這裏
Dialogue: 0,0:04:38.22,0:04:40.31,Default,,0,0,0,,逃跑真的沒問題嗎
Dialogue: 0,0:04:40.31,0:04:43.93,Default,,0,0,0,,小哥不是跟我們有仇嗎
Dialogue: 0,0:04:45.38,0:04:50.40,Default,,0,0,0,,有淵源的仇敵 可是味道深厚 極品的美食
Dialogue: 0,0:04:50.40,0:04:55.15,Default,,0,0,0,,讓我們暴飲暴食吧
Dialogue: 0,0:04:58.71,0:05:00.36,Default,,0,0,0,,對不起 蕾姆
Dialogue: 0,0:05:00.36,0:05:02.09,Default,,0,0,0,,再等我一下
Dialogue: 0,0:05:02.09,0:05:02.71,Default,,0,0,0,,走吧
Dialogue: 0,0:05:02.71,0:05:04.22,Default,,0,0,0,,戰乙女大人就交給你了
Dialogue: 0,0:05:04.22,0:05:05.11,Default,,0,0,0,,可別輸啊
Dialogue: 0,0:05:05.11,0:05:06.16,Default,,0,0,0,,由里
Dialogue: 0,0:05:08.13,0:05:10.76,Default,,0,0,0,,請…請不要放手
Dialogue: 0,0:05:18.36,0:05:19.73,Default,,0,0,0,,這就是魔法器
Dialogue: 0,0:05:20.44,0:05:21.05,Default,,0,0,0,,昴大人
Dialogue: 0,0:05:26.62,0:05:27.22,Default,,0,0,0,,那個
Dialogue: 0,0:05:27.82,0:05:29.18,Default,,0,0,0,,是人質
Dialogue: 0,0:05:30.93,0:05:31.77,Default,,0,0,0,,誰會讓妳得手
Dialogue: 0,0:05:36.89,0:05:37.53,Default,,0,0,0,,好
Dialogue: 0,0:05:39.42,0:05:40.70,Default,,0,0,0,,這招解決妳
Dialogue: 0,0:05:48.89,0:05:50.37,Default,,0,0,0,,我會做好周圍的警戒
Dialogue: 0,0:05:50.71,0:05:52.08,Default,,0,0,0,,昴大人請解救那個孩子
Dialogue: 0,0:05:53.82,0:05:54.58,Default,,0,0,0,,我明白了
Dialogue: 0,0:05:57.56,0:05:58.76,Default,,0,0,0,,沒事了
Dialogue: 0,0:05:58.76,0:06:01.38,Default,,0,0,0,,可怕的龍被姐姐打倒了
Dialogue: 0,0:06:03.16,0:06:06.04,Default,,0,0,0,,其他人呢 妳知道他們在哪嗎
Dialogue: 0,0:06:06.04,0:06:08.18,Default,,0,0,0,,在…在那邊的房間
Dialogue: 0,0:06:37.02,0:06:38.53,Default,,0,0,0,,這是…甚麼…
Dialogue: 0,0:06:39.51,0:06:40.80,Default,,0,0,0,,昴大人…
Dialogue: 0,0:06:41.33,0:06:41.96,Default,,0,0,0,,庫珥修小姐
Dialogue: 0,0:06:45.69,0:06:48.26,Default,,0,0,0,,你們為甚麼會這麼高興
Dialogue: 0,0:06:48.58,0:06:49.64,Default,,0,0,0,,妳
Dialogue: 0,0:06:49.64,0:06:54.22,Default,,0,0,0,,你以為人家是可憐軟弱的人質小女孩嗎
Dialogue: 0,0:07:00.58,0:07:02.03,Default,,0,0,0,,移開妳的腳
Dialogue: 0,0:07:03.47,0:07:08.71,Default,,0,0,0,,你是對人家的美足有所執着嗎
Dialogue: 0,0:07:08.71,0:07:11.33,Default,,0,0,0,,還是說是因為這團雌肉
Dialogue: 0,0:07:14.31,0:07:17.46,Default,,0,0,0,,畢竟她的身體很色
Dialogue: 0,0:07:17.79,0:07:22.53,Default,,0,0,0,,我是在說她不是妳的擱腳墊
Dialogue: 0,0:07:22.53,0:07:23.96,Default,,0,0,0,,給我打中
Dialogue: 0,0:07:23.96,0:07:24.55,Default,,0,0,0,,可以啊
Dialogue: 0,0:07:40.89,0:07:43.16,Default,,0,0,0,,你這甚麼表情
Dialogue: 0,0:07:43.16,0:07:46.53,Default,,0,0,0,,見識到人家的美麗後 連聲音都發不出嗎
Dialogue: 0,0:07:46.53,0:07:48.49,Default,,0,0,0,,妳怎麼回事
Dialogue: 0,0:07:49.02,0:07:52.95,Default,,0,0,0,,不知道從肉屑的角度看來 人家像甚麼
Dialogue: 0,0:07:52.95,0:07:54.13,Default,,0,0,0,,該不會
Dialogue: 0,0:07:54.80,0:07:57.16,Default,,0,0,0,,是化身成人的龍吧
Dialogue: 0,0:07:57.16,0:07:59.96,Default,,0,0,0,,好 充份體現出你無能的言論
Dialogue: 0,0:08:00.44,0:08:02.53,Default,,0,0,0,,我聽到了
Dialogue: 0,0:08:20.40,0:08:22.76,Default,,0,0,0,,變身了？
Dialogue: 0,0:08:25.78,0:08:30.09,Default,,0,0,0,,人家是魔女教大罪司教 色欲擔當的
Dialogue: 0,0:08:30.49,0:08:32.98,Default,,0,0,0,,卡培拉·艾美拉達·露格尼卡
Dialogue: 0,0:08:33.56,0:08:38.62,Default,,0,0,0,,人家也可以變身成你喜歡的美少女
Dialogue: 0,0:08:45.33,0:08:52.97,Default,,0,0,0,,就算是肉屑 也差不多該理解倒在那邊的蜥蝪和房間裏蒼蠅的真身了吧
Dialogue: 0,0:08:53.29,0:08:54.44,Default,,0,0,0,,等下
Dialogue: 0,0:08:54.93,0:08:56.71,Default,,0,0,0,,等下等下等下 給我等下
Dialogue: 0,0:08:56.71,0:08:59.81,Default,,0,0,0,,他們全都是這裏的人 是妳…
Dialogue: 0,0:09:00.22,0:09:01.29,Default,,0,0,0,,答對了
Dialogue: 0,0:09:01.29,0:09:04.22,Default,,0,0,0,,但因為答得太晚 沒有獎品
Dialogue: 0,0:09:05.96,0:09:07.82,Default,,0,0,0,,無法理解
Dialogue: 0,0:09:07.82,0:09:11.16,Default,,0,0,0,,為甚麼 為甚麼能做出這種事
Dialogue: 0,0:09:11.16,0:09:12.58,Default,,0,0,0,,居然將人變成蒼蠅
Dialogue: 0,0:09:13.24,0:09:14.12,Default,,0,0,0,,這有甚麼意義
Dialogue: 0,0:09:14.12,0:09:15.62,Default,,0,0,0,,你覺得可怕嗎
Dialogue: 0,0:09:15.62,0:09:17.33,Default,,0,0,0,,可怕到毛骨悚然
Dialogue: 0,0:09:17.33,0:09:19.24,Default,,0,0,0,,妳…你們…
Dialogue: 0,0:09:19.24,0:09:22.98,Default,,0,0,0,,沒錯 可怕 噁心 討厭
Dialogue: 0,0:09:23.38,0:09:24.79,Default,,0,0,0,,就是這個
Dialogue: 0,0:09:25.60,0:09:28.53,Default,,0,0,0,,看到他們 你從生理上覺得厭惡
Dialogue: 0,0:09:28.53,0:09:29.76,Default,,0,0,0,,這就是答案
Dialogue: 0,0:09:29.76,0:09:33.39,Default,,0,0,0,,那種生物 沒有人能去愛
Dialogue: 0,0:09:34.27,0:09:36.10,Default,,0,0,0,,妳倒不如殺掉他們
Dialogue: 0,0:09:36.98,0:09:38.00,Default,,0,0,0,,為甚麼
Dialogue: 0,0:09:38.00,0:09:42.27,Default,,0,0,0,,人家是博愛主義者 才不會做這麼野蠻的事
Dialogue: 0,0:09:42.27,0:09:46.89,Default,,0,0,0,,多一人也好 多一秒也好 多一句也好
Dialogue: 0,0:09:46.89,0:09:48.69,Default,,0,0,0,,人家想你們愛着人家
Dialogue: 0,0:09:50.67,0:09:51.32,Default,,0,0,0,,行嗎
Dialogue: 0,0:09:51.64,0:09:55.82,Default,,0,0,0,,這就是人家的請求
Dialogue: 0,0:10:01.60,0:10:02.29,Default,,0,0,0,,庫珥修小姐
Dialogue: 0,0:10:02.29,0:10:08.09,Default,,0,0,0,,你啊 到頭來還是渴求着雌肉 別把你的口水流出來
Dialogue: 0,0:10:08.40,0:10:09.71,Default,,0,0,0,,別說大話
Dialogue: 0,0:10:10.31,0:10:12.18,Default,,0,0,0,,我和她並不是
Dialogue: 0,0:10:12.18,0:10:13.59,Default,,0,0,0,,你閉嘴
Dialogue: 0,0:10:13.59,0:10:18.43,Default,,0,0,0,,你能發誓你一秒都沒想過下流的事嗎
Dialogue: 0,0:10:19.56,0:10:21.93,Default,,0,0,0,,你不想撫摸她的頭髮嗎
Dialogue: 0,0:10:21.93,0:10:25.11,Default,,0,0,0,,你不想觸碰她的嘴唇嗎
Dialogue: 0,0:10:25.11,0:10:27.73,Default,,0,0,0,,不能公開說出來的低劣感情
Dialogue: 0,0:10:27.73,0:10:31.40,Default,,0,0,0,,可別用愛來掩飾
Dialogue: 0,0:10:35.32,0:10:38.49,Default,,0,0,0,,看到這個 你還能繼續發表高論嗎
Dialogue: 0,0:10:40.62,0:10:44.58,Default,,0,0,0,,慣例的 約定俗成的 反對意見
Dialogue: 0,0:10:47.07,0:10:49.24,Default,,0,0,0,,我會愛上她是因為
Dialogue: 0,0:10:49.64,0:10:52.09,Default,,0,0,0,,我被她的內在美吸引住了
Dialogue: 0,0:10:52.53,0:10:55.02,Default,,0,0,0,,因為只有她認同我
Dialogue: 0,0:10:55.51,0:10:57.42,Default,,0,0,0,,在我痛苦的時候陪在我身邊
Dialogue: 0,0:10:57.87,0:11:01.56,Default,,0,0,0,,在她面前 我可以不作掩飾
Dialogue: 0,0:11:02.04,0:11:06.02,Default,,0,0,0,,和妳在一起 一切看上去都色彩斑爛
Dialogue: 0,0:11:06.67,0:11:08.86,Default,,0,0,0,,我已經無法一個人活下去了
Dialogue: 0,0:11:09.82,0:11:11.69,Default,,0,0,0,,在充滿虛偽的生活中
Dialogue: 0,0:11:12.27,0:11:15.60,Default,,0,0,0,,只有這份心意是真的
Dialogue: 0,0:11:19.47,0:11:22.98,Default,,0,0,0,,這全部不都是門面話嗎
Dialogue: 0,0:11:22.98,0:11:25.33,Default,,0,0,0,,如果兩個人真的是因為愛才在一起
Dialogue: 0,0:11:25.33,0:11:29.20,Default,,0,0,0,,對方變成蒼蠅後你也去愛她啊
Dialogue: 0,0:11:29.20,0:11:31.60,Default,,0,0,0,,能愛嗎 不能吧
Dialogue: 0,0:11:31.60,0:11:33.47,Default,,0,0,0,,畢竟很可怕啊
Dialogue: 0,0:11:33.47,0:11:36.09,Default,,0,0,0,,這是你自己說的吧
Dialogue: 0,0:11:40.31,0:11:41.69,Default,,0,0,0,,肉屑
Dialogue: 0,0:11:41.69,0:11:43.72,Default,,0,0,0,,看着本小姐
Dialogue: 0,0:11:49.33,0:11:50.98,Default,,0,0,0,,頭好痛
Dialogue: 0,0:11:50.98,0:11:54.67,Default,,0,0,0,,興奮過頭 亂了陣腳
Dialogue: 0,0:11:55.56,0:11:56.62,Default,,0,0,0,,好害羞
Dialogue: 0,0:12:01.64,0:12:04.09,Default,,0,0,0,,哎呀 這不快死了嗎
Dialogue: 0,0:12:04.71,0:12:05.56,Default,,0,0,0,,這邊也是
Dialogue: 0,0:12:06.40,0:12:07.64,Default,,0,0,0,,對了
Dialogue: 0,0:12:12.49,0:12:13.96,Default,,0,0,0,,妳想做甚麼
Dialogue: 0,0:12:14.40,0:12:18.27,Default,,0,0,0,,你們會成為多麼難看的肉塊
Dialogue: 0,0:12:18.27,0:12:21.01,Default,,0,0,0,,就讓人家來試試吧
Dialogue: 0,0:12:22.49,0:12:23.51,Default,,0,0,0,,很痛苦嗎
Dialogue: 0,0:12:23.51,0:12:25.22,Default,,0,0,0,,是不是很痛苦
Dialogue: 0,0:12:25.73,0:12:29.48,Default,,0,0,0,,人家的血中混着龍的血
Dialogue: 0,0:12:29.78,0:12:32.44,Default,,0,0,0,,要是輸給血的詛咒 就會變成不得了的東西
Dialogue: 0,0:12:33.64,0:12:37.69,Default,,0,0,0,,雌肉和你 到底誰能忍受住呢
Dialogue: 0,0:12:52.18,0:12:53.87,Default,,0,0,0,,挺厲害的嘛
Dialogue: 0,0:13:06.31,0:13:08.02,Default,,0,0,0,,臭顯擺的多手混蛋
Dialogue: 0,0:13:09.56,0:13:11.42,Default,,0,0,0,,從死角飛過來
Dialogue: 0,0:13:22.53,0:13:23.82,Default,,0,0,0,,大將
Dialogue: 0,0:13:26.62,0:13:27.45,Default,,0,0,0,,我明白了
Dialogue: 0,0:13:28.93,0:13:30.18,Default,,0,0,0,,安娜塔西亞大人
Dialogue: 0,0:13:30.67,0:13:32.44,Default,,0,0,0,,現在得知了一件很糟的事
Dialogue: 0,0:13:32.44,0:13:33.83,Default,,0,0,0,,發生甚麼了
Dialogue: 0,0:13:34.49,0:13:36.89,Default,,0,0,0,,和十人會失去聯絡了
Dialogue: 0,0:13:37.51,0:13:40.42,Default,,0,0,0,,首先能肯定 這是魔女教做的
Dialogue: 0,0:13:41.42,0:13:43.64,Default,,0,0,0,,奇利塔卡先生 咱想你也明白
Dialogue: 0,0:13:45.16,0:13:47.07,Default,,0,0,0,,我應該也是目標之一
Dialogue: 0,0:13:47.51,0:13:49.87,Default,,0,0,0,,安娜塔西亞大人 請您做好避難的準備
Dialogue: 0,0:13:49.87,0:13:51.60,Default,,0,0,0,,奇利塔卡先生打算怎麼做
Dialogue: 0,0:13:52.93,0:13:55.20,Default,,0,0,0,,可不能浪費生命
Dialogue: 0,0:13:55.87,0:13:57.32,Default,,0,0,0,,不管發生甚麼都要活下去
Dialogue: 0,0:13:59.64,0:14:00.76,Default,,0,0,0,,真讓我吃驚
Dialogue: 0,0:14:01.42,0:14:05.16,Default,,0,0,0,,我還以為您是個更無情的人
Dialogue: 0,0:14:05.73,0:14:10.13,Default,,0,0,0,,咱不是個沒血沒淚的為財鬼 讓您吃驚了嗎
Dialogue: 0,0:14:10.62,0:14:13.69,Default,,0,0,0,,當親愛客人的同伴就是我的座右銘
Dialogue: 0,0:14:13.69,0:14:15.17,Default,,0,0,0,,咱可是在行商
Dialogue: 0,0:14:18.93,0:14:20.93,Default,,600,0,0,,發生甚麼了 來人報告
Dialogue: 0,0:14:19.69,0:14:21.38,Default,,0,800,0,,對不起 謝謝
Dialogue: 0,0:14:22.22,0:14:24.27,Default,,0,0,0,,真是太美妙了
Dialogue: 0,0:14:26.49,0:14:27.47,Default,,0,0,0,,互相幫助
Dialogue: 0,0:14:27.91,0:14:31.07,Default,,0,0,0,,相互信任的感情讓大家活了下來
Dialogue: 0,0:14:31.60,0:14:33.07,Default,,0,0,0,,拍手！
Dialogue: 0,0:14:33.91,0:14:35.42,Default,,0,0,0,,憤怒的大罪司教
Dialogue: 0,0:14:37.16,0:14:39.91,Default,,0,0,0,,妳知道我啊
Dialogue: 0,0:14:39.91,0:14:41.78,Default,,0,0,0,,真讓人害羞
Dialogue: 0,0:14:42.40,0:14:45.16,Default,,0,0,0,,如果不是從一些不好事裏認識我就好了
Dialogue: 0,0:14:45.78,0:14:50.12,Default,,0,0,0,,我是憤怒擔當 西莉烏斯·羅曼尼康帝
Dialogue: 0,0:14:50.93,0:14:53.08,Default,,0,0,0,,以後請多多指教
Dialogue: 0,0:14:53.64,0:14:54.62,Default,,0,0,0,,能站起來嗎
Dialogue: 0,0:15:01.64,0:15:02.71,Default,,0,0,0,,安娜塔西亞大人
Dialogue: 0,0:15:11.78,0:15:13.43,Default,,0,0,0,,黑塔羅 提比
Dialogue: 0,0:15:13.78,0:15:14.44,Default,,0,0,0,,小姐
Dialogue: 0,0:15:14.44,0:15:15.87,Default,,0,0,0,,您沒事嗎
Dialogue: 0,0:15:16.22,0:15:18.44,Default,,0,0,0,,咱沒事 但蜜蜜呢
Dialogue: 0,0:15:18.44,0:15:19.02,Default,,0,0,0,,該不會
Dialogue: 0,0:15:19.02,0:15:20.69,Default,,0,0,0,,不是的 安娜塔西亞大人
Dialogue: 0,0:15:21.07,0:15:22.90,Default,,0,0,0,,菲利用了禁用手段
Dialogue: 0,0:15:23.16,0:15:25.32,Default,,0,0,0,,用了和昴的腳一樣的強硬手段
Dialogue: 0,0:15:26.44,0:15:27.41,Default,,0,0,0,,小姐
Dialogue: 0,0:15:27.41,0:15:29.42,Default,,0,0,0,,您一定要向前看
Dialogue: 0,0:15:29.42,0:15:34.00,Default,,0,0,0,,姐姐說過 就算處於痛苦當中也會幫助小姐的
Dialogue: 0,0:15:34.00,0:15:34.71,Default,,0,0,0,,小姐呢
Dialogue: 0,0:15:35.11,0:15:36.49,Default,,0,0,0,,小姐要怎樣做
Dialogue: 0,0:15:37.73,0:15:38.67,Default,,0,0,0,,咱要…
Dialogue: 0,0:15:41.78,0:15:43.11,Default,,0,0,0,,爭取時間
Dialogue: 0,0:15:43.11,0:15:44.72,Default,,0,0,0,,2分鐘 可以嗎
Dialogue: 0,0:15:45.24,0:15:48.18,Default,,0,0,0,,姐姐一定會說交給我們
Dialogue: 0,0:15:48.18,0:15:50.64,Default,,0,0,0,,這種情形下 能成功做到可帥氣了
Dialogue: 0,0:15:51.56,0:15:53.81,Default,,0,0,0,,真是可愛的兄弟愛
Dialogue: 0,0:15:54.18,0:15:56.06,Default,,0,0,0,,是雙胞胎嗎
Dialogue: 0,0:15:56.06,0:15:57.38,Default,,0,0,0,,很可惜
Dialogue: 0,0:15:57.38,0:15:59.52,Default,,0,0,0,,是三胞胎中的弟弟二人
Dialogue: 0,0:15:59.78,0:16:02.13,Default,,0,0,0,,菲利絲 你帶着蜜蜜他們出去
Dialogue: 0,0:16:02.13,0:16:03.29,Default,,0,0,0,,在外面匯合
Dialogue: 0,0:16:03.29,0:16:04.23,Default,,0,0,0,,明白了
Dialogue: 0,0:16:07.38,0:16:08.70,Default,,0,0,0,,少主 您沒事吧
Dialogue: 0,0:16:09.78,0:16:10.89,Default,,0,0,0,,請從那邊走出去
Dialogue: 0,0:16:10.89,0:16:13.20,Default,,0,0,0,,我和部下去吸引她注意
Dialogue: 0,0:16:18.13,0:16:19.33,Default,,0,0,0,,安娜塔西亞大人
Dialogue: 0,0:16:19.87,0:16:22.44,Default,,0,0,0,,這座都市 樸利斯提拉就拜託您了
Dialogue: 0,0:16:26.04,0:16:30.44,Default,,0,0,0,,這座美麗的水之都 還有我所愛的歌姬
Dialogue: 0,0:16:30.44,0:16:32.76,Default,,0,0,0,,請從邪惡手中保護他們
Dialogue: 0,0:16:34.80,0:16:36.89,Default,,0,0,0,,太狡猾了 這種做法
Dialogue: 0,0:16:48.76,0:16:50.11,Default,,0,0,0,,要喝嗎
Dialogue: 0,0:16:50.36,0:16:53.16,Default,,0,0,0,,別跟我說話 一身酒臭味
Dialogue: 0,0:17:06.40,0:17:07.91,Default,,0,0,0,,卓塔蟲嗎
Dialogue: 0,0:17:16.84,0:17:18.18,Default,,0,0,0,,對不起！
Dialogue: 0,0:17:24.67,0:17:26.44,Default,,0,0,0,,你想怎麼做
Dialogue: 0,0:17:26.93,0:17:29.36,Default,,0,0,0,,要斬了自己的親生父親嗎
Dialogue: 0,0:17:33.51,0:17:34.84,Default,,0,0,0,,菲魯特大人
Dialogue: 0,0:17:36.31,0:17:38.00,Default,,0,0,0,,好了 把他綁起來
Dialogue: 0,0:17:41.47,0:17:44.75,Default,,0,0,0,,一直保持着同一個姿勢 搞得我屁股痛
Dialogue: 0,0:17:46.00,0:17:48.59,Default,,0,0,0,,雖然我還不清楚情況
Dialogue: 0,0:17:49.24,0:17:50.71,Default,,0,0,0,,現在的結果算好嗎
Dialogue: 0,0:17:51.16,0:17:53.22,Default,,0,0,0,,你是 昴的…
Dialogue: 0,0:17:54.93,0:17:56.22,Default,,0,0,0,,這樣啊
Dialogue: 0,0:17:56.22,0:17:58.62,Default,,0,0,0,,剛才的卓塔蟲是你的絕招
Dialogue: 0,0:17:58.62,0:18:00.49,Default,,0,0,0,,謝謝你 幫大忙了
Dialogue: 0,0:18:00.49,0:18:01.87,Default,,0,0,0,,才沒有幫上忙
Dialogue: 0,0:18:02.67,0:18:06.58,Default,,0,0,0,,比起被劍架着脖子 我100倍覺得要死了
Dialogue: 0,0:18:07.11,0:18:08.53,Default,,0,0,0,,快給精神賠償金
Dialogue: 0,0:18:08.89,0:18:12.44,Default,,0,0,0,,我覺得我應該是您的救命恩人
Dialogue: 0,0:18:14.04,0:18:15.24,Default,,0,0,0,,你為甚麼會在這裏
Dialogue: 0,0:18:15.73,0:18:18.04,Default,,0,0,0,,我還以為你和昴在一起
Dialogue: 0,0:18:18.53,0:18:20.33,Default,,0,0,0,,偶然而已
Dialogue: 0,0:18:21.07,0:18:24.25,Default,,0,0,0,,我想找個能藏身的地方
Dialogue: 0,0:18:24.84,0:18:26.71,Default,,0,0,0,,你遇到了暴食的大罪司教？
Dialogue: 0,0:18:27.11,0:18:28.21,Default,,0,0,0,,真虧你能平安逃脫
Dialogue: 0,0:18:28.58,0:18:30.84,Default,,0,0,0,,都是多虧有白龍之鱗的各位幫忙
Dialogue: 0,0:18:31.33,0:18:34.04,Default,,0,0,0,,如果沒有他們在 我現在已經…
Dialogue: 0,0:18:35.24,0:18:36.58,Default,,0,0,0,,昴他們是否安全？
Dialogue: 0,0:18:37.07,0:18:38.04,Default,,0,0,0,,我不知道
Dialogue: 0,0:18:38.62,0:18:42.18,Default,,0,0,0,,既然是他 我想他肯定會堅毅地站起來奮鬥
Dialogue: 0,0:18:42.67,0:18:43.96,Default,,0,0,0,,喂 廢柴
Dialogue: 0,0:18:44.98,0:18:47.02,Default,,0,0,0,,現在不用擔心了吧
Dialogue: 0,0:18:47.42,0:18:49.36,Default,,0,0,0,,你快點過去幫忙
Dialogue: 0,0:18:49.82,0:18:50.27,Default,,0,0,0,,不行
Dialogue: 0,0:18:50.67,0:18:51.29,Default,,0,0,0,,我留在您…
Dialogue: 0,0:18:51.29,0:18:54.36,Default,,0,0,0,,你剛才的動作是打算救我嗎
Dialogue: 0,0:18:55.64,0:18:58.93,Default,,0,0,0,,我會帶着這傢伙去附近的避難所
Dialogue: 0,0:18:59.33,0:19:01.16,Default,,0,0,0,,你不要想這麼多
Dialogue: 0,0:19:01.16,0:19:02.80,Default,,0,0,0,,快去把所有事情解決掉
Dialogue: 0,0:19:04.40,0:19:05.38,Default,,0,0,0,,萊因哈魯特
Dialogue: 0,0:19:06.31,0:19:07.11,Default,,0,0,0,,領命
Dialogue: 0,0:19:07.96,0:19:09.96,Default,,0,0,0,,請您不要勉強
Dialogue: 0,0:19:09.96,0:19:11.82,Default,,0,0,0,,你就盡情勉強吧
Dialogue: 0,0:19:12.49,0:19:14.17,Default,,0,0,0,,讓他們見識見識
Dialogue: 0,0:19:19.87,0:19:20.85,Default,,0,0,0,,好了
Dialogue: 0,0:19:21.24,0:19:22.98,Default,,0,0,0,,到底要怎麼做
Dialogue: 0,0:19:22.98,0:19:24.89,Default,,0,0,0,,背他走實在是背不動
Dialogue: 0,0:19:24.89,0:19:28.27,Default,,0,0,0,,為甚麼我們要做這種跑腿一樣的工作
Dialogue: 0,0:19:28.27,0:19:29.29,Default,,0,0,0,,沒辦法啊
Dialogue: 0,0:19:29.29,0:19:31.82,Default,,0,0,0,,避難所的食物快吃完了
Dialogue: 0,0:19:35.16,0:19:36.74,Default,,0,0,0,,這是第一次吧
Dialogue: 0,0:19:36.74,0:19:39.64,Default,,0,0,0,,在正需要你們的時候出現
Dialogue: 0,0:19:42.93,0:19:43.75,Default,,0,0,0,,怎麼了
Dialogue: 0,0:19:44.44,0:19:45.83,Default,,0,0,0,,他們甚麼時候走掉的
Dialogue: 0,0:19:48.76,0:19:49.82,Default,,0,0,0,,別開玩笑了
Dialogue: 0,0:20:05.51,0:20:06.64,Default,,0,0,0,,嘉飛爾先生
Dialogue: 0,0:20:08.49,0:20:11.23,Default,,0,0,0,,可惡 到底發生甚麼了
Dialogue: 0,0:20:27.29,0:20:28.33,Default,,0,0,0,,大將
Dialogue: 0,0:20:33.51,0:20:34.09,Default,,0,0,0,,等下
Dialogue: 0,0:20:51.42,0:20:52.94,Default,,0,0,0,,大將！
Dialogue: 0,0:22:32.31,0:22:33.51,Default,,0,0,0,,怎麼會
Dialogue: 0,0:22:34.31,0:22:35.17,Default,,0,0,0,,整座城市…
Dialogue: 0,0:22:35.91,0:22:37.73,Default,,0,0,0,,不能露出這種表情
Dialogue: 0,0:22:37.73,0:22:39.38,Default,,0,0,0,,夫君會不喜歡的
Dialogue: 0,0:22:39.38,0:22:40.76,Default,,0,0,0,,妳在說甚麼
Dialogue: 0,0:22:40.76,0:22:41.78,Default,,0,0,0,,不是說這種話的時候吧
Dialogue: 0,0:22:42.53,0:22:44.58,Default,,0,0,0,,各位肉屑
Dialogue: 0,0:22:44.58,0:22:45.18,Default,,0,0,0,,這是甚麼
Dialogue: 0,0:22:44.58,0:22:48.58,Default,,1200,0,0,,今天也精神地在顫抖捲縮嗎
Dialogue: 0,0:22:48.58,0:22:53.64,Default,,0,0,0,,是色欲大罪司教 卡培拉大人的美聲廣播
Dialogue: 0,0:22:55.07,0:22:57.61,Default,,0,0,0,,好了 明明都說了這麼多次
Dialogue: 0,0:22:57.61,0:23:02.49,Default,,0,0,0,,但還是有大量的肉屑來襲擊我們
Dialogue: 0,0:23:02.49,0:23:04.44,Default,,0,0,0,,本小姐非常受傷
Dialogue: 0,0:23:04.44,0:23:07.07,Default,,0,0,0,,所以呢 除了魔女的遺骨
Dialogue: 0,0:23:07.07,0:23:10.84,Default,,0,0,0,,還要追加三個要求
Dialogue: 0,0:23:11.20,0:23:16.67,Default,,0,0,0,,一個是獻上應該帶到這個都市裏的睿智之書
Dialogue: 0,0:23:16.67,0:23:22.44,Default,,0,0,0,,一個是獻上在這個都市中悠然活着的人工精靈
Dialogue: 0,0:23:22.44,0:23:24.22,Default,,0,0,0,,而最後是
Dialogue: 0,0:23:24.22,0:23:28.72,Default,,0,0,0,,在這個都市舉行與銀髮少女的婚禮
Dialogue: 0,0:23:29.16,0:23:32.18,Default,,0,0,0,,應該是在說不要來搞事吧
Dialogue: 0,0:23:32.18,0:23:34.68,Default,,0,0,0,,這件事根本不關人家事
