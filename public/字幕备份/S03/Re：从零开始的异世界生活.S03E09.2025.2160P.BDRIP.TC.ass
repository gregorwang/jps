Dialogue: 0,0:22:05.97,0:22:06.01,screen,,0,0,0,,{\an5\pos(960,150)\fs150\c&HFFFFFF&\bord0}混戰都市
Comment: 0,0:00:00.00,0:00:00.00,screen,,0,0,0,,
Comment: 0,0:00:00.00,0:00:00.00,Default,,0,0,0,,
Dialogue: 0,0:00:05.03,0:00:06.80,Default,,0,0,0,,等 等下
Dialogue: 0,0:00:06.80,0:00:08.91,Default,,0,0,0,,普莉希拉大人
Dialogue: 0,0:00:11.26,0:00:16.63,Default,,0,0,0,,既然要帶着歌姬過去 妾身也得換一套合適的服裝
Dialogue: 0,0:00:16.63,0:00:18.74,Default,,0,0,0,,感謝 感謝
Dialogue: 0,0:00:19.33,0:00:20.46,Default,,0,0,0,,不對
Dialogue: 0,0:00:21.31,0:00:23.14,Default,,0,0,0,,都來到了決戰時刻
Dialogue: 0,0:00:23.14,0:00:25.42,Default,,0,0,0,,但跟您去的人就只有我
Dialogue: 0,0:00:25.94,0:00:28.23,Default,,0,0,0,,起碼也帶上您隨從的阿爾先生…
Dialogue: 0,0:00:28.23,0:00:30.30,Default,,0,0,0,,阿爾只是一個小丑罷了
Dialogue: 0,0:00:30.30,0:00:33.10,Default,,0,0,0,,說到底 妾身一個人有甚麼不足
Dialogue: 0,0:00:33.10,0:00:34.97,Default,,0,0,0,,確實！
Dialogue: 0,0:00:34.97,0:00:38.29,Default,,0,0,0,,有着巨乳的普莉希拉大人簡直就是神明
Dialogue: 0,0:00:38.29,0:00:40.52,Default,,0,0,0,,怎麼了
Dialogue: 0,0:00:41.03,0:00:43.83,Default,,0,0,0,,看到了一個不得了的畫面呢
Dialogue: 0,0:00:45.37,0:00:46.57,Default,,0,0,0,,女狐狸嗎
Dialogue: 0,0:00:46.57,0:00:49.71,Default,,0,0,0,,真是的 每次見到人就叫人做女狐狸
Dialogue: 0,0:00:49.71,0:00:51.11,Default,,0,0,0,,妳不覺得有點過份嗎
Dialogue: 0,0:00:51.83,0:00:55.60,Default,,0,0,0,,是關係大家出發後 市政廳的防守
Dialogue: 0,0:00:55.60,0:00:58.29,Default,,0,0,0,,當我們都出控制塔之後
Dialogue: 0,0:00:58.29,0:01:00.37,Default,,0,0,0,,那些貪婪的流氓
Dialogue: 0,0:01:00.37,0:01:02.88,Default,,0,0,0,,肯定會以無人值守的大本營為目標
Dialogue: 0,0:01:03.60,0:01:05.30,Default,,0,0,0,,阿爾他隨妳用
Dialogue: 0,0:01:05.60,0:01:07.54,Default,,0,0,0,,真是爽快
Dialogue: 0,0:01:08.34,0:01:12.23,Default,,0,0,0,,原來如此 普莉希拉大人相信着阿爾先生…
Dialogue: 0,0:01:14.00,0:01:17.09,Default,,0,0,0,,妾身相不相信他又是另一件事了
Dialogue: 0,0:01:17.77,0:01:19.81,Default,,0,0,0,,他也有很多不能說的事
Dialogue: 0,0:01:19.81,0:01:21.31,Default,,0,0,0,,而且
Dialogue: 0,0:01:21.31,0:01:25.09,Default,,0,0,0,,妳也有不少秘密吧
Dialogue: 0,0:01:26.06,0:01:27.20,Default,,0,0,0,,女狐狸
Dialogue: 0,0:01:27.83,0:01:29.82,Default,,0,0,0,,誰知道呢 不清楚妳在說甚麼
Dialogue: 0,0:01:30.17,0:01:32.29,Default,,0,0,0,,妳裝無知那是妳的事
Dialogue: 0,0:01:32.29,0:01:35.71,Default,,0,0,0,,妳就儘管對自己的騎士和目標
Dialogue: 0,0:01:35.71,0:01:38.79,Default,,0,0,0,,抱着見不得人的罪惡感吧
Dialogue: 0,0:01:39.31,0:01:41.71,Default,,0,0,0,,說着這麼難聽的話
Dialogue: 0,0:01:41.71,0:01:43.50,Default,,0,0,0,,那麼 妳是有甚麼計劃嗎
Dialogue: 0,0:01:44.80,0:01:47.14,Default,,0,0,0,,妳覺得妾身需要那些無趣的小動作嗎
Dialogue: 0,0:01:47.71,0:01:48.84,Default,,0,0,0,,帶着歌姬
Dialogue: 0,0:01:49.31,0:01:51.43,Default,,0,0,0,,正面闖過去
Dialogue: 0,0:03:33.03,0:03:35.43,Default,,0,0,0,,說實話 咱很想阻止你
Dialogue: 0,0:03:35.43,0:03:40.91,Default,,0,0,0,,但也想清楚魔女教想要的睿智之書的準確位置
Dialogue: 0,0:03:40.91,0:03:42.37,Default,,0,0,0,,你真是抽中了下下籤
Dialogue: 0,0:03:42.37,0:03:43.77,Default,,0,0,0,,奧托
Dialogue: 0,0:03:44.87,0:03:46.62,Default,,0,0,0,,要命
Dialogue: 0,0:03:48.97,0:03:49.83,Default,,0,0,0,,他們是
Dialogue: 0,0:03:49.83,0:03:51.59,Default,,0,0,0,,菲魯特大人？
Dialogue: 0,0:03:51.59,0:03:54.21,Default,,0,0,0,,歡迎你 小哥哥
Dialogue: 0,0:03:55.14,0:03:59.26,Default,,0,0,0,,歡迎來到魔女教大罪司教 暴食擔當
Dialogue: 0,0:03:59.71,0:04:03.66,Default,,0,0,0,,萊伊·巴登凱托斯的狩獵場
Dialogue: 0,0:04:14.91,0:04:16.29,Default,,0,0,0,,這個只能稱之為異形
Dialogue: 0,0:04:17.09,0:04:18.15,Default,,0,0,0,,這就是
Dialogue: 0,0:04:18.15,0:04:20.51,Default,,0,0,0,,色欲的大罪司教
Dialogue: 0,0:04:23.71,0:04:25.45,Default,,0,0,0,,來了
Dialogue: 0,0:04:27.60,0:04:28.71,Default,,0,0,0,,嘉飛爾殿下
Dialogue: 0,0:04:30.17,0:04:34.00,Default,,0,0,0,,那個女劍士的真身 是我的妻子
Dialogue: 0,0:04:34.40,0:04:37.47,Default,,0,0,0,,前代劍聖 特蕾西亞
Dialogue: 0,0:04:38.74,0:04:42.60,Default,,0,0,0,,但 我聽說前代劍聖
Dialogue: 0,0:04:42.60,0:04:45.03,Default,,0,0,0,,被白鯨打倒了
Dialogue: 0,0:04:45.03,0:04:47.60,Default,,0,0,0,,這個仇我已經報了
Dialogue: 0,0:04:47.60,0:04:48.81,Default,,0,0,0,,本應是的
Dialogue: 0,0:04:49.49,0:04:50.65,Default,,0,0,0,,但是
Dialogue: 0,0:04:51.54,0:04:54.86,Default,,0,0,0,,他們玩弄亡妻的遺體
Dialogue: 0,0:04:54.86,0:04:57.09,Default,,0,0,0,,踐踏他們的靈魂
Dialogue: 0,0:04:57.09,0:05:01.26,Default,,0,0,0,,讓妻子向她過去所保護的人揮劍
Dialogue: 0,0:05:01.71,0:05:02.66,Default,,0,0,0,,這根本就
Dialogue: 0,0:05:02.66,0:05:04.97,Default,,0,0,0,,原諒不了
Dialogue: 0,0:05:12.17,0:05:16.17,Default,,0,0,0,,簡直是坐在火上的奧雷古蓮
Dialogue: 0,0:05:16.17,0:05:19.54,Default,,0,0,0,,我要讓你們後悔走出來
Dialogue: 0,0:05:37.94,0:05:39.57,Default,,0,0,0,,別小看人
Dialogue: 0,0:06:01.94,0:06:03.43,Default,,0,0,0,,特蕾西亞
Dialogue: 0,0:06:11.26,0:06:15.54,Default,,0,0,0,,歌姬 妳關心的是歌姬狂熱者吧
Dialogue: 0,0:06:16.34,0:06:18.02,Default,,0,0,0,,是的
Dialogue: 0,0:06:18.57,0:06:21.24,Default,,0,0,0,,我對奇利塔卡先生…
Dialogue: 0,0:06:22.69,0:06:26.95,Default,,0,0,0,,考慮到他們的要求 那個男人應該還活着
Dialogue: 0,0:06:27.77,0:06:29.03,Default,,0,0,0,,真的嗎
Dialogue: 0,0:06:29.03,0:06:33.14,Default,,0,0,0,,既然只有十人會的人知道魔女遺骨的位置
Dialogue: 0,0:06:33.14,0:06:34.86,Default,,0,0,0,,那當然要讓他活着
Dialogue: 0,0:06:34.86,0:06:40.69,Default,,0,0,0,,既然是這樣 那十人會的人被依次盯上不就很奇怪嗎
Dialogue: 0,0:06:40.69,0:06:44.97,Default,,0,0,0,,那是因為殺掉十人會的人不是他們
Dialogue: 0,0:06:45.37,0:06:49.94,Default,,0,0,0,,是想妨礙魔女教的小人搶先出手了
Dialogue: 0,0:06:50.80,0:06:54.81,Default,,0,0,0,,那普莉希拉大人是不是知道那些小人…
Dialogue: 0,0:07:04.06,0:07:08.11,Default,,0,0,0,,要妳們特要走過來 對不起
Dialogue: 0,0:07:11.60,0:07:12.97,Default,,0,0,0,,謝謝
Dialogue: 0,0:07:17.21,0:07:18.33,Default,,0,0,0,,昴
Dialogue: 0,0:07:18.33,0:07:21.09,Default,,0,0,0,,棒極的E·M·T!
Dialogue: 0,0:07:21.09,0:07:23.26,Default,,0,0,0,,現在先把感想放在一邊
Dialogue: 0,0:07:23.26,0:07:25.42,Default,,0,0,0,,看來剛好趕上了
Dialogue: 0,0:07:25.77,0:07:29.03,Default,,0,0,0,,不講理的不貞女的出軌對象就是你嗎
Dialogue: 0,0:07:29.03,0:07:31.20,Default,,0,0,0,,真是難以理解
Dialogue: 0,0:07:31.20,0:07:33.06,Default,,0,0,0,,先不說旁邊的紅毛
Dialogue: 0,0:07:33.37,0:07:36.63,Default,,0,0,0,,甩了我去找的人居然是你？
Dialogue: 0,0:07:36.63,0:07:40.17,Default,,0,0,0,,她的眼球是玻璃做的嗎
Dialogue: 0,0:07:40.17,0:07:42.46,Default,,0,0,0,,給我用寶石來形容
Dialogue: 0,0:07:42.46,0:07:45.83,Default,,0,0,0,,還有 你拿我旁邊的人做比較我真的無話可說 你就別了吧
Dialogue: 0,0:07:46.57,0:07:48.69,Default,,0,0,0,,是甚麼來着 劍聖？
Dialogue: 0,0:07:48.69,0:07:50.40,Default,,0,0,0,,聽是有聽過
Dialogue: 0,0:07:50.40,0:07:53.62,Default,,0,0,0,,不就是一個只會揮劍的無能嗎
Dialogue: 0,0:07:54.06,0:07:55.71,Default,,0,0,0,,這形容很奇怪 但確實說到點
Dialogue: 0,0:07:55.71,0:07:59.33,Default,,0,0,0,,不過 我不太清楚我現在能不能做到你說的事
Dialogue: 0,0:07:59.77,0:08:02.80,Default,,0,0,0,,這把龍劍是從阿斯特雷亞初代家主一直傳承下來
Dialogue: 0,0:08:03.26,0:08:05.51,Default,,0,0,0,,世界最強的劍
Dialogue: 0,0:08:06.11,0:08:08.22,Default,,0,0,0,,但有一個缺點
Dialogue: 0,0:08:09.49,0:08:14.57,Default,,0,0,0,,如果對手不值得拔劍的話 這把劍是拔不出來的
Dialogue: 0,0:08:16.00,0:08:16.74,Default,,0,0,0,,也就是說
Dialogue: 0,0:08:19.26,0:08:23.73,Default,,0,0,0,,看來 劍覺得你還不配做對手
Dialogue: 0,0:08:24.97,0:08:26.61,Default,,0,0,0,,我說啊
Dialogue: 0,0:08:26.61,0:08:30.28,Default,,0,0,0,,劍聖連劍都拔不出來 還有甚麼用
Dialogue: 0,0:08:30.69,0:08:33.66,Default,,0,0,0,,別自大了 下三流
Dialogue: 0,0:08:34.00,0:08:34.91,Default,,0,0,0,,昴 過來
Dialogue: 0,0:08:37.08,0:08:38.57,Default,,0,0,0,,別動
Dialogue: 0,0:08:38.57,0:08:41.75,Default,,0,0,0,,要是敢輕舉妄動 她們的生命就到此為止
Dialogue: 0,0:08:43.31,0:08:47.55,Default,,0,0,0,,這種情況下沒理由還能保持冷靜吧
Dialogue: 0,0:08:47.94,0:08:50.01,Default,,0,0,0,,這些人怎麼一回事
Dialogue: 0,0:08:50.40,0:08:53.77,Default,,0,0,0,,她們都是我重要的妻子
Dialogue: 0,0:08:53.77,0:08:55.39,Default,,0,0,0,,如果你們想要抵抗
Dialogue: 0,0:08:55.89,0:08:59.20,Default,,0,0,0,,那我就不得不殺死我心愛的她們
Dialogue: 0,0:08:59.71,0:09:01.69,Default,,0,0,0,,要我做這麼殘忍的事
Dialogue: 0,0:09:01.69,0:09:03.81,Default,,0,0,0,,你們是名符其實的惡魔
Dialogue: 0,0:09:03.81,0:09:07.32,Default,,0,0,0,,不好 完全溝通不了
Dialogue: 0,0:09:07.83,0:09:10.74,Default,,0,0,0,,雖然直接動手的人是我
Dialogue: 0,0:09:10.74,0:09:12.95,Default,,0,0,0,,但讓我動手的人是你們
Dialogue: 0,0:09:13.54,0:09:17.31,Default,,0,0,0,,即是說你們把我當作道具來殺人
Dialogue: 0,0:09:17.31,0:09:18.86,Default,,0,0,0,,可惡的殺妻凶手
Dialogue: 0,0:09:18.86,0:09:19.83,Default,,0,0,0,,我的存在
Dialogue: 0,0:09:21.09,0:09:22.17,Default,,0,0,0,,你可別忘了
Dialogue: 0,0:09:26.00,0:09:27.21,Default,,0,0,0,,你大意了
Dialogue: 0,0:09:28.00,0:09:29.14,Default,,0,0,0,,是你輸了
Dialogue: 0,0:09:29.94,0:09:31.31,Default,,0,0,0,,我說啊
Dialogue: 0,0:09:31.31,0:09:35.71,Default,,0,0,0,,我剛才明明把他們逼到絕境了
Dialogue: 0,0:09:35.71,0:09:39.43,Default,,0,0,0,,是向妻子們展示 不愧是夫君 的場合吧
Dialogue: 0,0:09:39.43,0:09:41.23,Default,,0,0,0,,現在馬上釋放她們
Dialogue: 0,0:09:41.23,0:09:43.94,Default,,0,0,0,,不行 艾米莉亞 這樣是阻止不了他的
Dialogue: 0,0:09:44.31,0:09:45.40,Default,,0,0,0,,真是的
Dialogue: 0,0:09:48.69,0:09:51.54,Default,,0,0,0,,沒娶妳回去果然是對的
Dialogue: 0,0:09:55.31,0:09:59.20,Default,,0,0,0,,暴力 又不會尊重男人
Dialogue: 0,0:09:59.20,0:10:02.17,Default,,0,0,0,,即便心靈和身體都是處女也沒有意義
Dialogue: 0,0:10:02.17,0:10:03.83,Default,,0,0,0,,妳這個不講理的女人
Dialogue: 0,0:10:03.83,0:10:06.40,Default,,0,0,0,,居然玩弄我的純情
Dialogue: 0,0:10:06.84,0:10:08.21,Default,,0,0,0,,快住手 蠢材！
Dialogue: 0,0:10:08.21,0:10:09.60,Default,,0,0,0,,蠢材？
Dialogue: 0,0:10:09.60,0:10:13.43,Default,,0,0,0,,你才是蠢材吧 你是不是沒看清現狀
Dialogue: 0,0:10:13.43,0:10:16.51,Default,,0,0,0,,還是說 你已經放棄思考了
Dialogue: 0,0:10:17.37,0:10:18.29,Default,,0,0,0,,我明白了
Dialogue: 0,0:10:18.91,0:10:22.31,Default,,0,0,0,,請放開抓住艾米莉亞大人的手 我會聽你的要求
Dialogue: 0,0:10:22.91,0:10:24.86,Default,,0,0,0,,沒錯沒錯 就應該這樣
Dialogue: 0,0:10:24.86,0:10:27.31,Default,,0,0,0,,這就是所謂的謙虛
Dialogue: 0,0:10:28.17,0:10:30.65,Default,,0,0,0,,放下星之劍 然後過來這邊
Dialogue: 0,0:10:44.51,0:10:45.77,Default,,0,0,0,,停下
Dialogue: 0,0:10:46.86,0:10:50.57,Default,,0,0,0,,我要你在那裏承受我一次攻擊
Dialogue: 0,0:10:50.57,0:10:52.72,Default,,0,0,0,,不能擋 也不能避
Dialogue: 0,0:10:53.09,0:10:57.22,Default,,0,0,0,,這樣就當作一筆勾銷
Dialogue: 0,0:10:57.54,0:10:59.77,Default,,0,0,0,,我明白了 我接受
Dialogue: 0,0:10:59.77,0:11:00.60,Default,,0,0,0,,萊因哈魯特
Dialogue: 0,0:11:00.60,0:11:03.85,Default,,0,0,0,,你是有甚麼辦法吧 我相信你
Dialogue: 0,0:11:04.29,0:11:06.11,Default,,0,0,0,,昴 我們約好了
Dialogue: 0,0:11:06.11,0:11:09.26,Default,,0,0,0,,你會補全我不足的部份吧
Dialogue: 0,0:11:10.15,0:11:13.77,Default,,0,0,0,,很好的覺悟 我向你表達敬意
Dialogue: 0,0:11:24.34,0:11:28.67,Default,,0,0,0,,不管是甚麼人 在迎接死亡時都是一樣地無趣
Dialogue: 0,0:11:29.14,0:11:31.20,Default,,0,0,0,,你滿足地死去了嗎
Dialogue: 0,0:11:35.20,0:11:39.09,Default,,0,0,0,,和高潔的他相比 你還真是醜陋
Dialogue: 0,0:11:39.09,0:11:41.49,Default,,0,0,0,,你是沒看到我有人質嗎
Dialogue: 0,0:11:41.49,0:11:42.80,Default,,0,0,0,,這就奇怪了
Dialogue: 0,0:11:45.26,0:11:46.77,Default,,0,0,0,,按你所說的
Dialogue: 0,0:11:47.37,0:11:49.77,Default,,0,0,0,,你應該要釋放人質
Dialogue: 0,0:12:10.51,0:12:13.42,Default,,0,0,0,,萊伊·巴登凱托斯
Dialogue: 0,0:12:14.00,0:12:19.26,Default,,0,0,0,,果然和在市政廳見到的暴食不是同一人
Dialogue: 0,0:12:20.57,0:12:23.97,Default,,0,0,0,,不只是小弟們 還認識我們嗎
Dialogue: 0,0:12:24.29,0:12:27.26,Default,,0,0,0,,這就是說暴食有兩個
Dialogue: 0,0:12:27.26,0:12:30.81,Default,,0,0,0,,不對 正確地說是最少有兩個
Dialogue: 0,0:12:32.00,0:12:34.63,Default,,0,0,0,,很好 你的理解能力不錯
Dialogue: 0,0:12:34.63,0:12:38.45,Default,,0,0,0,,而且看清楚後 你不就是之前小弟們沒吃到的
Dialogue: 0,0:12:38.45,0:12:41.16,Default,,0,0,0,,前菜嗎
Dialogue: 0,0:12:43.77,0:12:46.40,Default,,0,0,0,,現在不是友好地交談的時候吧
Dialogue: 0,0:12:46.40,0:12:50.51,Default,,0,0,0,,真的要打嗎 對手可是大罪司教
Dialogue: 0,0:12:50.51,0:12:53.50,Default,,0,0,0,,你不是說在聽到女兒叫你爸爸之前不想死嗎
Dialogue: 0,0:12:53.89,0:12:57.31,up,,0,0,0,,請不要這麼悲觀
Dialogue: 0,0:12:57.31,0:13:02.00,up,,0,0,0,,不管是何種相遇 都是為了讓美食更加美味的步驟
Dialogue: 0,0:13:02.00,0:13:04.46,up,,0,0,0,,雖然我們被人叫做暴食
Dialogue: 0,0:13:04.46,0:13:09.23,up,,0,0,0,,但我們還是知道食材的前處理有多麼重要
Dialogue: 0,0:13:04.86,0:13:05.66,Default,,0,0,0,,我記得
Dialogue: 0,0:13:06.46,0:13:09.23,Default,,0,0,0,,你們是奇利塔卡先生的護衛 白龍之鱗
Dialogue: 0,0:13:09.83,0:13:11.94,Default,,0,0,0,,艾米莉亞大人的內政官嗎
Dialogue: 0,0:13:11.94,0:13:13.83,Default,,0,0,0,,我們都沒有運氣
Dialogue: 0,0:13:14.97,0:13:19.32,Default,,0,0,0,,根本說不上是主力的隊伍遇上了敵人的主力
Dialogue: 0,0:13:19.77,0:13:21.31,Default,,0,0,0,,這笑話也太不好笑了
Dialogue: 0,0:13:21.31,0:13:22.99,Default,,0,0,0,,才不想被你說
Dialogue: 0,0:13:22.99,0:13:26.06,Default,,0,0,0,,喂喂 不要吵架不要吵架
Dialogue: 0,0:13:26.06,0:13:28.63,Default,,0,0,0,,反正都是了 不如合作吧
Dialogue: 0,0:13:28.63,0:13:30.25,Default,,0,0,0,,找到小弟們在找的東西
Dialogue: 0,0:13:31.03,0:13:33.63,Default,,0,0,0,,我們想知道的只有一個
Dialogue: 0,0:13:34.00,0:13:38.46,Default,,0,0,0,,剛才進行廣播的那位英雄的所在地
Dialogue: 0,0:13:38.46,0:13:41.66,Default,,0,0,0,,那位親愛的親愛的英雄
Dialogue: 0,0:13:41.66,0:13:44.85,Default,,0,0,0,,他是要來審判小弟們吧
Dialogue: 0,0:13:45.20,0:13:47.89,Default,,0,0,0,,這顆小小的心臟在渴求着他
Dialogue: 0,0:13:47.89,0:13:51.77,Default,,0,0,0,,高昴地 激昴地躍動着 快要跳出來了
Dialogue: 0,0:13:52.34,0:13:53.52,Default,,0,0,0,,他的話
Dialogue: 0,0:13:53.52,0:13:55.83,Default,,0,0,0,,我剛剛還跟他在一起
Dialogue: 0,0:13:56.97,0:13:59.03,Default,,0,0,0,,你知道 你知道啊
Dialogue: 0,0:13:59.03,0:14:02.06,Default,,0,0,0,,我們英雄的位置
Dialogue: 0,0:14:02.06,0:14:05.07,Default,,0,0,0,,親愛的親愛的英雄的身姿
Dialogue: 0,0:14:06.80,0:14:12.37,Default,,0,0,0,,那個柔弱的 脆弱的 沒人幫助他就會不安到不能自已
Dialogue: 0,0:14:12.37,0:14:14.12,Default,,0,0,0,,那個人
Dialogue: 0,0:14:15.83,0:14:17.77,Default,,0,0,0,,沒錯 是的
Dialogue: 0,0:14:18.63,0:14:21.54,Default,,0,0,0,,要不我帶你去吧
Dialogue: 0,0:14:21.54,0:14:23.38,Default,,0,0,0,,我也想珍惜生命
Dialogue: 0,0:14:24.00,0:14:26.60,Default,,0,0,0,,只要你原意保證我們生命安全
Dialogue: 0,0:14:25.09,0:14:26.60,up,,0,0,0,,你啊
Dialogue: 0,0:14:27.09,0:14:28.81,up,,0,0,0,,是商人吧
Dialogue: 0,0:14:29.77,0:14:31.71,Default,,0,0,0,,果然是
Dialogue: 0,0:14:31.71,0:14:36.11,Default,,0,0,0,,把萬物標上價格 賣給別人 獨食自肥
Dialogue: 0,0:14:36.51,0:14:39.94,Default,,0,0,0,,把人的價值 想法 全部都…
Dialogue: 0,0:14:39.94,0:14:44.61,Default,,0,0,0,,全部都放上天平 換成錢的亡命之徒
Dialogue: 0,0:14:42.69,0:14:44.97,up,,0,0,0,,我覺得你的理解不太正確…
Dialogue: 0,0:14:44.97,0:14:48.03,Default,,0,0,0,,誰會被你騙到 才不可能上當
Dialogue: 0,0:14:48.03,0:14:51.62,Default,,0,0,0,,誰會聽你們這種人說的話
Dialogue: 0,0:14:51.62,0:14:53.03,Default,,0,0,0,,為甚麼突然變成這樣
Dialogue: 0,0:14:53.03,0:14:55.62,Default,,0,0,0,,肯定是有過不好的回憶吧
Dialogue: 0,0:14:56.34,0:14:59.84,Default,,0,0,0,,說到底 世界就是暴飲暴食
Dialogue: 0,0:14:59.84,0:15:00.75,Default,,0,0,0,,要來了
Dialogue: 0,0:15:00.75,0:15:03.01,Default,,0,0,0,,我開動了
Dialogue: 0,0:15:03.01,0:15:07.14,Default,,0,0,0,,和商人談生意 一定要談到最後
Dialogue: 0,0:15:11.37,0:15:13.56,Default,,0,0,0,,因為我有絕對的殺手鐧
Dialogue: 0,0:15:20.29,0:15:21.82,Default,,0,0,0,,果然
Dialogue: 0,0:15:22.40,0:15:25.20,Default,,0,0,0,,來見我們了
Dialogue: 0,0:15:25.83,0:15:28.16,Default,,0,0,0,,我好感激啊
Dialogue: 0,0:15:28.16,0:15:31.26,Default,,0,0,0,,那就是暴食的大罪司教
Dialogue: 0,0:15:31.26,0:15:32.17,Default,,0,0,0,,里卡多
Dialogue: 0,0:15:33.60,0:15:37.03,Default,,0,0,0,,一來就用上全力 配合我
Dialogue: 0,0:15:37.03,0:15:38.38,Default,,0,0,0,,好 交給我
Dialogue: 0,0:15:43.13,0:15:51.31,Default,,0,0,0,,很好 很棒 真的好棒 非常好 好吧 這很不錯 正因為好
Dialogue: 0,0:15:51.94,0:15:54.73,Default,,0,0,0,,暴飲暴食！
Dialogue: 0,0:15:55.09,0:15:58.91,Default,,0,0,0,,精靈騎士 由里烏斯·尤克歷烏斯 絕不會大意
Comment: 0,0:16:00.29,0:16:02.61,Default,,0,0,0,,(超·克雷塞利亞,Al Clauseria)
Dialogue: 0,0:16:00.29,0:16:02.61,Default,,0,0,0,,超·克雷塞利亞
Dialogue: 0,0:16:00.29,0:16:02.61,Default,,0,0,0,,{\fs39\pos(960,995)}Al Clauseria
Dialogue: 0,0:16:04.51,0:16:09.70,Default,,0,0,0,,兄長大人完全符合我們的預期 太棒了
Dialogue: 0,0:16:15.54,0:16:16.69,Default,,0,0,0,,您沒事嗎
Dialogue: 0,0:16:17.31,0:16:18.08,Default,,0,0,0,,艾米莉亞碳
Dialogue: 0,0:16:18.57,0:16:19.71,Default,,0,0,0,,妳沒事吧
Dialogue: 0,0:16:19.71,0:16:21.09,Default,,0,0,0,,嗯 小事而已
Dialogue: 0,0:16:21.60,0:16:22.29,Default,,0,0,0,,謝謝
Dialogue: 0,0:16:22.63,0:16:25.76,Default,,0,0,0,,我相信你一定會來的
Dialogue: 0,0:16:25.76,0:16:29.84,Default,,0,0,0,,我也相信妳會相信我 等着我
Dialogue: 0,0:16:30.86,0:16:36.06,Default,,0,0,0,,我如果要結婚 那當然只能和我喜歡的人結婚
Dialogue: 0,0:16:36.06,0:16:37.66,Default,,0,0,0,,就是啊
Dialogue: 0,0:16:37.66,0:16:40.06,Default,,0,0,0,,太好了 我放心了
Dialogue: 0,0:16:40.06,0:16:42.34,Default,,0,0,0,,能問一下 妳喜歡的人…
Dialogue: 0,0:16:43.14,0:16:44.74,Default,,0,0,0,,昴 你的腳
Dialogue: 0,0:16:44.74,0:16:45.65,Default,,0,0,0,,這個嗎
Dialogue: 0,0:16:46.06,0:16:47.03,Default,,0,0,0,,沒事吧
Dialogue: 0,0:16:47.03,0:16:50.06,Default,,0,0,0,,雖然看上去很嚴重 但其實沒甚麼
Dialogue: 0,0:16:50.06,0:16:53.03,Default,,0,0,0,,比起我 萊因哈魯特 你沒事吧
Dialogue: 0,0:16:54.29,0:16:54.97,Default,,0,0,0,,不得了
Dialogue: 0,0:16:54.97,0:16:57.31,Default,,0,0,0,,你快脫掉衣服 我來治療
Dialogue: 0,0:16:57.31,0:17:00.67,Default,,0,0,0,,抱歉讓你們擔心了 我沒事的
Dialogue: 0,0:17:01.26,0:17:03.42,Default,,0,0,0,,你們看 沒有傷口
Dialogue: 0,0:17:04.91,0:17:08.38,Default,,0,0,0,,既然是你 我也相信你會有方法
Dialogue: 0,0:17:08.38,0:17:10.86,Default,,0,0,0,,但這方法也太預料之外了
Dialogue: 0,0:17:10.86,0:17:13.14,Default,,0,0,0,,你能相信我 我很高興
Dialogue: 0,0:17:13.14,0:17:15.77,Default,,0,0,0,,靠着不死鳥的加護 復活了一次
Dialogue: 0,0:17:15.77,0:17:17.94,Default,,0,0,0,,但實際上也是短短死了一會
Dialogue: 0,0:17:17.94,0:17:20.11,Default,,0,0,0,,才不是短短死了一會
Dialogue: 0,0:17:20.11,0:17:21.23,Default,,0,0,0,,你是白痴嗎
Dialogue: 0,0:17:21.66,0:17:24.80,Default,,0,0,0,,對不起 我認為這是最佳做法
Dialogue: 0,0:17:25.37,0:17:28.36,Default,,0,0,0,,不過 可以的話我也不想再死了
Dialogue: 0,0:17:28.36,0:17:30.63,Default,,0,0,0,,這也是當然的
Dialogue: 0,0:17:31.14,0:17:32.29,Default,,0,0,0,,說回來
Dialogue: 0,0:17:33.07,0:17:35.58,Default,,0,0,0,,根據剛才說的內容
Dialogue: 0,0:17:35.58,0:17:37.26,Default,,0,0,0,,她們都是…
Dialogue: 0,0:17:37.26,0:17:38.04,Default,,0,0,0,,沒錯
Dialogue: 0,0:17:38.74,0:17:41.00,Default,,0,0,0,,都是雷古魯斯的妻子
Dialogue: 0,0:17:41.49,0:17:44.86,Default,,0,0,0,,我非常不想承認
Dialogue: 0,0:17:44.86,0:17:48.40,Default,,0,0,0,,受到這種對待 怎麼可能是幸福的新娘
Dialogue: 0,0:17:48.40,0:17:49.97,Default,,0,0,0,,我說啊
Dialogue: 0,0:17:49.97,0:17:53.94,Default,,0,0,0,,對我做了這種事 還這樣和和氣氣的 你們是怎麼想的
Dialogue: 0,0:17:53.94,0:17:57.18,Default,,0,0,0,,沒有人性也得有個度啊
Dialogue: 0,0:17:57.18,0:17:58.51,Default,,0,0,0,,原來如此
Dialogue: 0,0:17:58.51,0:18:01.09,Default,,0,0,0,,跟聽說的一樣 確實是位奇特的對手
Dialogue: 0,0:18:01.09,0:18:04.57,Default,,0,0,0,,對付他 如果不能真正解開他無敵的原因
Dialogue: 0,0:18:04.57,0:18:05.26,Default,,0,0,0,,根本對付不…
Dialogue: 0,0:18:08.23,0:18:11.61,Default,,0,0,0,,昴 正如商量一樣 我來當他的對手
Dialogue: 0,0:18:12.11,0:18:14.00,Default,,0,0,0,,你去找應對無敵的方法
Dialogue: 0,0:18:15.07,0:18:16.69,Default,,0,0,0,,好 艾米莉亞碳
Dialogue: 0,0:18:17.83,0:18:21.71,Default,,0,0,0,,妳沒事吧 有沒有哪裏受傷了
Dialogue: 0,0:18:21.71,0:18:24.86,Default,,0,0,0,,我 我們留在這裏
Dialogue: 0,0:18:24.86,0:18:27.09,Default,,0,0,0,,為甚麼 是腳痛嗎
Dialogue: 0,0:18:27.09,0:18:28.80,Default,,0,0,0,,是的話我來背妳
Dialogue: 0,0:18:29.26,0:18:31.76,Default,,0,0,0,,還沒有得到夫君的許可
Dialogue: 0,0:18:33.22,0:18:36.29,Default,,0,0,0,,要是沒得到夫君的許可便擅自行動
Dialogue: 0,0:18:36.29,0:18:38.97,Default,,0,0,0,,就會觸及夫君的憤怒
Dialogue: 0,0:18:39.31,0:18:42.51,Default,,0,0,0,,我明白妳們害怕他
Dialogue: 0,0:18:42.51,0:18:45.20,Default,,0,0,0,,但是 對手可是劍聖萊因哈魯特
Dialogue: 0,0:18:45.20,0:18:47.20,Default,,0,0,0,,一定能打倒雷古魯斯
Dialogue: 0,0:18:47.20,0:18:49.54,Default,,0,0,0,,不管對手是誰都一樣
Dialogue: 0,0:18:50.40,0:18:51.83,Default,,0,0,0,,到底有誰可以打贏夫君…
Dialogue: 0,0:18:52.74,0:18:55.28,Default,,0,0,0,,到底有誰可以打贏雷古魯斯·柯尼亞斯
Dialogue: 0,0:18:57.14,0:18:57.74,Default,,0,0,0,,昴？
Dialogue: 0,0:18:59.49,0:19:01.50,Default,,0,0,0,,萊因哈魯特 改變計劃
Dialogue: 0,0:19:04.00,0:19:06.08,Default,,0,0,0,,你是甚麼東西啊
Dialogue: 0,0:19:06.08,0:19:09.31,Default,,0,0,0,,改變計劃？昴 那裏面的女性呢
Dialogue: 0,0:19:09.31,0:19:11.80,Default,,0,0,0,,這是甚麼 你是從哪裏發聲的
Dialogue: 0,0:19:12.40,0:19:14.40,Default,,0,0,0,,這是傳心的加護
Dialogue: 0,0:19:14.40,0:19:17.71,Default,,0,0,0,,在目視範圍內的朋友 傳個聲不是問題
Dialogue: 0,0:19:17.71,0:19:20.17,Default,,0,0,0,,你離人類越來越遠了
Dialogue: 0,0:19:20.17,0:19:22.00,Default,,0,0,0,,總之要改變計劃
Dialogue: 0,0:19:22.00,0:19:24.06,Default,,0,0,0,,改為實行計劃I
Dialogue: 0,0:19:26.06,0:19:30.40,Default,,0,0,0,,看來你也一樣有着非常怪物級的實力
Dialogue: 0,0:19:30.40,0:19:34.19,Default,,0,0,0,,但腦子不行 就跟拿着寶物的白痴一樣
Dialogue: 0,0:19:34.57,0:19:37.54,Default,,0,0,0,,確實 所以接下來
Dialogue: 0,0:19:38.69,0:19:42.08,Default,,0,0,0,,就讓我試一試比較迂迴的做法
Dialogue: 0,0:19:42.63,0:19:45.94,Default,,0,0,0,,你這個聽不懂人話的
Dialogue: 0,0:19:49.20,0:19:51.83,Default,,0,0,0,,昴 等下 你想怎麼做
Dialogue: 0,0:19:52.59,0:19:54.97,Default,,0,0,0,,艾米莉亞碳 好大膽
Dialogue: 0,0:19:54.97,0:19:58.18,Default,,0,0,0,,因為這條裙雖然很可愛 但活動很不方便
Dialogue: 0,0:19:58.18,0:20:01.31,Default,,0,0,0,,比起這個 你想讓萊因哈魯特做甚麼
Dialogue: 0,0:20:01.31,0:20:04.34,Default,,0,0,0,,來這裏之前想的其中一個作戰
Dialogue: 0,0:20:04.34,0:20:07.94,Default,,0,0,0,,畢竟要找到方法打破雷古魯斯的無敵
Dialogue: 0,0:20:08.34,0:20:12.51,Default,,0,0,0,,就是個將想到的可能逐個去試的計劃
Dialogue: 0,0:20:13.66,0:20:15.43,Default,,0,0,0,,錯的是雷古魯斯
Dialogue: 0,0:20:15.43,0:20:17.90,Default,,0,0,0,,所以我不會責怪妳們
Dialogue: 0,0:20:18.17,0:20:20.40,Default,,0,0,0,,但是 起碼讓我說一句
Dialogue: 0,0:20:20.40,0:20:24.29,Default,,0,0,0,,不管怎麼樣 要是不說出來甚麼都不會開始
Dialogue: 0,0:20:24.29,0:20:26.40,Default,,0,0,0,,不能不張開眼
Dialogue: 0,0:20:26.40,0:20:28.04,Default,,0,0,0,,在眼皮下
Dialogue: 0,0:20:28.04,0:20:31.03,Default,,0,0,0,,沒有想看的事物 也沒有明天
Dialogue: 0,0:20:31.03,0:20:32.63,Default,,0,0,0,,昴 我們走吧
Dialogue: 0,0:20:32.63,0:20:34.23,Default,,0,0,0,,我們也要去戰鬥
Dialogue: 0,0:21:05.31,0:21:09.09,Default,,0,0,0,,現在害怕能有甚麼用
Dialogue: 0,0:21:09.09,0:21:13.71,Default,,0,0,0,,大將和奧托哥哥他們都在等我
Dialogue: 0,0:21:15.60,0:21:17.96,Default,,0,0,0,,除了戰鬥…
Dialogue: 0,0:21:17.96,0:21:20.68,Default,,0,0,0,,我甚麼都不會
Dialogue: 0,0:21:21.14,0:21:22.68,Default,,0,0,0,,嘉飛爾殿下 上面
Dialogue: 0,0:21:27.43,0:21:30.10,Default,,0,0,0,,色欲…不對
Dialogue: 0,0:21:40.46,0:21:43.26,Default,,0,0,0,,我們合力保護這座都市吧
Dialogue: 0,0:21:44.53,0:21:47.31,Default,,0,0,0,,要奪回我們的都市
Dialogue: 0,0:21:48.97,0:21:51.77,Default,,0,0,0,,來吧 開始正義的決戰
Dialogue: 0,0:21:55.09,0:21:56.69,Default,,0,0,0,,開玩笑
Dialogue: 0,0:22:00.11,0:22:01.54,Default,,0,0,0,,妳是
Dialogue: 0,0:22:04.06,0:22:05.97,Default,,0,0,0,,本小姐的
Dialogue: 0,0:22:06.40,0:22:09.03,Default,,0,0,0,,登場！
